{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "dmytro-lol",
    "compatibility_date": "2025-10-07",
    "assets": {
      "directory": "./dist",
      "not_found_handling": "404-page"
    },
    "routes": [
      {
        "pattern": "dmytro.lol",
        "custom_domain": true,
      }
    ]
  }